		{
			"name": "E2E Test Scenario",
			"item": [
				{
					"name": "1. Create Account",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"pm.test(\"Response has user_id and balance\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('user_id');",
									"    pm.expect(jsonData).to.have.property('balance');",
									"    pm.expect(jsonData.balance).to.eql(0);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"user_id\": \"999\"\n}"
						},
						"url": {
							"raw": "http://localhost:8081/accounts",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8081",
							"path": [
								"accounts"
							]
						}
					},
					"response": []
				},
				{
					"name": "2. Topup Account",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Balance increased\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.balance).to.be.at.least(1000);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": 1000\n}"
						},
						"url": {
							"raw": "http://localhost:8081/accounts/999/topup",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8081",
							"path": [
								"accounts",
								"999",
								"topup"
							]
						}
					},
					"response": []
				},
				{
					"name": "3. Create Order",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 202\", function () {",
									"    pm.response.to.have.status(202);",
									"});",
									"pm.test(\"Order created with PENDING status\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('order_id');",
									"    pm.expect(jsonData.status).to.eql('PENDING');",
									"    pm.environment.set('order_id', jsonData.order_id);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"user_id\": \"999\",\n  \"amount\": 500,\n  \"items\": []\n}"
						},
						"url": {
							"raw": "http://localhost:8080/orders",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8080",
							"path": [
								"orders"
							]
						}
					},
					"response": []
				},
				{
					"name": "4. Wait and Check Order Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"setTimeout(function() {}, 2000);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8080/orders/{{order_id}}",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8080",
							"path": [
								"orders",
								"{{order_id}}"
							]
						}
					},
					"response": []
				},
				{
					"name": "5. Verify Balance Decreased",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Balance decreased by order amount\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.balance).to.eql(500);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8081/accounts/999/balance",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8081",
							"path": [
								"accounts",
								"999",
								"balance"
							]
						}
					},
					"response": []
				}
			],
			"description": "Полный E2E сценарий: создание счета → пополнение → создание заказа → проверка статуса и баланса"
		}
	],
